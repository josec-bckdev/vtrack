# VTrack Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=vtrack_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vtrack_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# For local development (outside Docker):
# DATABASE_URL=postgresql://vtrack_user:your_secure_password_here@localhost:5432/vtrack_db

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379/0

# For local development (outside Docker):
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# TELEGRAM NOTIFICATION CONFIGURATION
# ============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Get your chat ID from @userinfobot on Telegram
# Note: This is kept for backward compatibility
# Multi-user configuration is in microservices/notification-sender/users.yaml
TELEGRAM_CHAT_ID=123456789

# ============================================================================
# COOKIE REFRESH (integrated VNC browser automation)
# ============================================================================
# VNC browser control API — started on-demand via docker compose --profile tools
VNC_BROWSER_URL=http://vnc-browser:8080
VNC_CONTAINER_NAME=vnc_browser
# Path inside the api container where programmed_steps.json is mounted
PROGRAMMED_STEPS_PATH=/data/programmed_steps.json
# Proactive refresh cron schedules (America/Bogota) — run 5 min before collection
COOKIE_REFRESH_SCHEDULE_MORNING=40 5 * * 1-5
COOKIE_REFRESH_SCHEDULE_AFTERNOON=10 15 * * 1-5

# ============================================================================
# SCRAPER CREDENTIALS
# ============================================================================
# Credentials for the data source you're scraping
LOGIN_EMAIL=your_email@example.com
LOGIN_PASSWORD=your_scraper_password

# ============================================================================
# PGADMIN CONFIGURATION (Optional - for database management UI)
# ============================================================================
PGADMIN_EMAIL=admin@vtrack.local
PGADMIN_PASSWORD=admin_secure_password

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Set to "1" for testing mode (uses SQLite instead of PostgreSQL)
TESTING=0

# Polling interval for alert processor (seconds)
POLL_INTERVAL=2

# Environment mode (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# OPTIONAL: MONITORING & LOGGING
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# NOTES:
# ============================================================================
# 1. After copying to .env, fill in all values marked with "your_..."
# 2. Generate secure passwords for production use
# 3. Never commit .env to version control (it's in .gitignore)
# 4. For Telegram setup:
#    - Create bot: https://t.me/BotFather
#    - Get chat ID: https://t.me/userinfobot
# 5. Multi-user Telegram config: microservices/notification-sender/users.yaml
